{
  "name": "loopar-framework",
  "sideEffects": false,
  "version": "6.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "node bin/setup/installer-clean.js",
    "postinstall": "node bin/setup/ensure-site.js",
    "start": "node bin/cli/index.js start",
    "stop": "node bin/cli/index.js stop",
    "restart": "node bin/cli/index.js restart",
    "kill": "node bin/cli/index.js kill",
    "startup": "node bin/cli/index.js startup",
    "logs": "node bin/cli/index.js logs",
    "tui": "node bin/tui/index.js",
    "deps": "yarn install --immutable --inline-builds",
    "watch": "node bin/cli/index.js watch",
    "activate": "node bin/build/activate-staging.js",
    "build": "node bin/build/prepare.js && yarn build:client && yarn build:server && node bin/build/activate.js",
    "build:client": "node bin/build/run-vite.js client",
    "build:server": "node bin/build/run-vite.js server"
  },
  "bin": {
    "loopar": "./bin/cli/index.js"
  },
  "packageManager": "yarn@4.13.0"
}
