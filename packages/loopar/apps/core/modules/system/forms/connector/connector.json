{
  "name": "Connector",
  "__APP__": "core",
  "__ENTITY__": "Form Builder",
  "doc_structure": [
    {
      "element": "card",
      "node": "card_main",
      "data": {
        "label": "Database connection",
        "key": "card1_el173793814043"
      },
      "elements": [
        {
          "element": "select",
          "node": "select_dialect",
          "data": {
            "name": "dialect",
            "label": "Engine",
            "options": "mysql\nmariadb\npostgres\nsqlite\nmssql",
            "required": true,
            "default_value": "mysql",
            "description": "SQLite uses a local file. The other engines require a running server."
          },
          "elements": []
        },
        {
          "element": "card",
          "node": "card_conn",
          "data": {
            "label": "Server",
            "display_on": "dialect != 'sqlite'"
          },
          "elements": [
            {
              "element": "input",
              "node": "input_host",
              "data": {
                "label": "Host",
                "name": "host",
                "default_value": "localhost"
              },
              "elements": []
            },
            {
              "element": "input",
              "node": "input_port",
              "data": {
                "label": "Port",
                "name": "port",
                "format": "int",
                "description": "mysql/mariadb: 3306 — postgres: 5432 — mssql: 1433"
              },
              "elements": []
            },
            {
              "element": "input",
              "node": "input_user",
              "data": {
                "label": "User",
                "name": "user",
                "default_value": "root"
              },
              "elements": []
            },
            {
              "element": "password",
              "node": "password_pwd",
              "data": {
                "label": "Password",
                "name": "password"
              },
              "elements": []
            }
          ]
        },
        {
          "element": "button",
          "node": "button_connect",
          "data": {
            "label": "Connect",
            "key": "button1_el1074140857913",
            "variant": "destructive",
            "class": "w-full",
            "action": "connect"
          }
        }
      ]
    }
  ]
}
